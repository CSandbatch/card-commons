# Required in production

# OpenRouter unified image API — powers most selectable models.
OPENROUTER_API_KEY=
# Optional: attribution headers sent to OpenRouter.
OPENROUTER_SITE_URL=https://card-commons.example

# Direct OpenAI path — only needed for the "OpenAI GPT-Image (direct)" model.
OPENAI_API_KEY=
OPENAI_IMAGE_MODEL=gpt-image-2

PILOT_ACCESS_HASH=
SESSION_SIGNING_SECRET=

# Tests and local UI work only; never enable in a live pilot.
STUDIO_MOCK_IMAGES=false
